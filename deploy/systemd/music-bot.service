[Unit]
Description=Telegram Music Bot (Go)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=musicbot
Group=musicbot
WorkingDirectory=/opt/music-bot
EnvironmentFile=/etc/music-bot/music-bot.env
ExecStart=/opt/music-bot/music-bot
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/music-bot

[Install]
WantedBy=multi-user.target